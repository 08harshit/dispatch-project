# Server
PORT=4000
NODE_ENV=development

# Supabase (required)
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# CORS (production only - comma-separated origins)
# CORS_ORIGINS=https://admin.example.com,https://courier.example.com

# Cron (optional - when set, cron endpoints require X-Cron-Secret header)
# CRON_SECRET=your-cron-secret

# Notifications (optional - Resend API for emails)
# RESEND_API_KEY=re_xxx
# NOTIFICATION_FROM_EMAIL=notifications@yourdomain.com
